# Raspberry Pi 4 Configuration
# Copy this file to .env and adjust values for your setup

# ---- MODEL ----
MODEL_PATH=best.pt
MODEL_IMGSZ=320
CONF_THRESHOLD=0.45

# ---- CAMERA ----
CAMERA_INDEX=0
CAPTURE_WIDTH=640
CAPTURE_HEIGHT=480

# ---- PERFORMANCE ----
# Process/detect every Nth frame. Higher = faster FPS, more detection lag.
# 1 = every frame (slowest), 3 = every 3rd frame (recommended), 5+ = very fast
SKIP_FRAMES=3

# ---- STREAMING ----
STREAM_WIDTH=640
STREAM_HEIGHT=480
TARGET_FPS=10

# ---- DASHBOARD ----
# URL of your Flask server on Render (after deployment)
# Replace with your Render URL, e.g.: https://traffic-monitoring-dashboard.onrender.com
SERVER_URL=https://your-app.onrender.com/upload

# Frame upload endpoint (same server)
FRAME_URL=https://your-app.onrender.com/frame

# ---- LOGGING ----
DEBUG=1
LOG_FILE=detection.log

# ---- OPTIONAL: ONNX (faster than PyTorch) ----
USE_ONNX=0
