# Raspberry Pi 4 Configuration
# Copy this file to .env and adjust values for your setup

# ---- MODEL ----
MODEL_PATH=best.pt
MODEL_IMGSZ=320
CONF_THRESHOLD=0.45

# ---- CAMERA ----
CAMERA_INDEX=0
CAPTURE_WIDTH=640
CAPTURE_HEIGHT=480

# ---- PERFORMANCE ----
# Process/detect every Nth frame. Higher = faster FPS, more detection lag.
# 1 = every frame (slowest), 3 = every 3rd frame (recommended), 5+ = very fast
SKIP_FRAMES=3

# ---- STREAMING ----
STREAM_WIDTH=640
STREAM_HEIGHT=480
TARGET_FPS=10

# ---- DASHBOARD (optional) ----
# URL of your Flask server from the main project
SERVER_URL=http://127.0.0.1:5000/upload

# ---- LOGGING ----
DEBUG=1
LOG_FILE=detection.log

# ---- OPTIONAL: ONNX (faster than PyTorch) ----
USE_ONNX=0
